# Cloudflare Pages / Netlify headers — appliqués si déployé sur ces plateformes.
/*
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet, noimageindex, noai, noimageai
  X-Frame-Options: DENY
  Content-Security-Policy: frame-ancestors 'none'
  Referrer-Policy: no-referrer
  X-Content-Type-Options: nosniff
  Permissions-Policy: geolocation=(self), microphone=(self), camera=(self), gyroscope=(self), accelerometer=(self), magnetometer=(self), browsing-topics=()
